# Razorpay (leave blank to run in offline mode — orders persist as pending)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Commerce policy (optional overrides — defaults: free shipping, no tax)
# SHIPPING_FLAT_INR=0
# FREE_SHIP_OVER_INR=0
# TAX_RATE=0

# Stable secret for checkout/confirmation HMAC tokens (>=16 chars).
# Without it, tokens use an ephemeral per-process secret (see checkout-token.ts).
CHECKOUT_TOKEN_SECRET=

# Postgres migration (see docs/postgres-migration-plan.md). Until DB_DRIVER
# flips to "postgres", the sqlite path stays active and these are unused.
# DATABASE_URL must be the POOLED connection string (Neon pooler / PgBouncer).
DB_DRIVER=sqlite
DATABASE_URL=
# DATABASE_POOL_MAX=3
# Seed (scripts/seed.mjs) — set a real owner password before seeding prod:
# SEED_OWNER_EMAIL=
# SEED_OWNER_PASSWORD=
# SEED_OWNER_NAME=
